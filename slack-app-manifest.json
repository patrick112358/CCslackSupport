{
  "display_information": {
    "name": "IT Support Bot",
    "description": "Classifies #it-support messages and creates ClickUp tasks automatically",
    "background_color": "#2c2d30"
  },
  "features": {
    "bot_user": {
      "display_name": "IT Support Bot",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:history",
        "channels:read",
        "chat:write",
        "reactions:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.channels"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
